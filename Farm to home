<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Farm to Home — Fresh From the Field</title>
<meta name="description" content="Fresh farm produce delivered to your home. Shop jams, honey, dairy, and more from local Indian farmers.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,300;0,700;0,900;1,400;1,700&family=Nunito:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --green-dark: #1B4332;
  --green-mid: #2D6A4F;
  --green-light: #52B788;
  --green-pale: #D8F3DC;
  --green-soft: #EEF7EF;
  --gold: #E9A824;
  --gold-light: #FFF3CD;
  --orange: #E76F2A;
  --cream: #FDFAF4;
  --warm: #F5ECD7;
  --earth: #5C3D1E;
  --text: #1A1A1A;
  --muted: #6B7280;
  --white: #FFFFFF;
  --red: #D62828;
}

html { scroll-behavior: smooth; }

body {
  font-family: 'Nunito', sans-serif;
  background: var(--cream);
  color: var(--text);
  overflow-x: hidden;
  cursor: none;
}

/* Custom Cursor */
.cursor {
  width: 14px; height: 14px;
  background: var(--green-mid);
  border-radius: 50%;
  position: fixed;
  pointer-events: none;
  z-index: 99999;
  transform: translate(-50%,-50%);
  transition: transform 0.1s, width 0.2s, height 0.2s, background 0.2s;
}
.cursor-ring {
  width: 36px; height: 36px;
  border: 2px solid var(--green-light);
  border-radius: 50%;
  position: fixed;
  pointer-events: none;
  z-index: 99998;
  transform: translate(-50%,-50%);
  transition: transform 0.15s ease, width 0.2s, height 0.2s, opacity 0.2s;
  opacity: 0.6;
}

/* ── NAV ── */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 500;
  padding: 0 2.5rem;
  height: 68px;
  display: flex; align-items: center; justify-content: space-between;
  background: rgba(253,250,244,0.93);
  backdrop-filter: blur(20px);
  border-bottom: 1px solid rgba(82,183,136,0.15);
  transition: box-shadow 0.3s;
}
nav.scrolled { box-shadow: 0 4px 24px rgba(27,67,50,0.1); }

.logo {
  display: flex; align-items: center; gap: 0.6rem;
  text-decoration: none; font-family: 'Fraunces', serif;
  font-size: 1.5rem; font-weight: 900; color: var(--green-dark);
}
.logo-leaf { font-size: 1.6rem; animation: sway 3s ease-in-out infinite; }
@keyframes sway {
  0%,100% { transform: rotate(-5deg); }
  50% { transform: rotate(5deg); }
}
.logo span { color: var(--orange); }

.nav-center {
  display: flex; gap: 0.3rem; align-items: center;
  background: var(--green-soft);
  border-radius: 100px;
  padding: 0.3rem;
}
.nav-link {
  padding: 0.4rem 1rem;
  border-radius: 100px;
  text-decoration: none;
  font-size: 0.88rem;
  font-weight: 700;
  color: var(--green-dark);
  transition: all 0.2s;
  border: none; background: transparent; cursor: pointer; font-family: 'Nunito', sans-serif;
}
.nav-link:hover, .nav-link.active { background: var(--green-dark); color: var(--white); }

.nav-right { display: flex; align-items: center; gap: 0.75rem; }

.nav-icon-btn {
  width: 42px; height: 42px;
  background: transparent; border: 1.5px solid rgba(27,67,50,0.15);
  border-radius: 12px; display: flex; align-items: center;
  justify-content: center; font-size: 1.1rem; cursor: pointer;
  transition: all 0.2s; position: relative;
}
.nav-icon-btn:hover { background: var(--green-pale); border-color: var(--green-light); }

.badge {
  position: absolute; top: -5px; right: -5px;
  background: var(--orange); color: white;
  width: 18px; height: 18px; border-radius: 50%;
  font-size: 0.65rem; font-weight: 800;
  display: flex; align-items: center; justify-content: center;
  font-family: 'Nunito', sans-serif;
}

.btn-sell {
  padding: 0.5rem 1.3rem;
  background: var(--green-dark); color: white;
  border: none; border-radius: 100px;
  font-family: 'Nunito', sans-serif;
  font-size: 0.88rem; font-weight: 800; cursor: pointer;
  transition: all 0.2s;
}
.btn-sell:hover { background: var(--green-mid); transform: translateY(-1px); box-shadow: 0 6px 16px rgba(27,67,50,0.25); }

/* ── HERO ── */
.hero {
  min-height: 100vh;
  background: var(--green-dark);
  position: relative;
  overflow: hidden;
  display: flex; flex-direction: column;
  justify-content: center;
  padding: 7rem 3rem 4rem;
}

/* Animated background circles */
.hero-blob {
  position: absolute; border-radius: 50%;
  animation: float 6s ease-in-out infinite;
}
.blob1 { width: 500px; height: 500px; background: radial-gradient(circle, rgba(82,183,136,0.2), transparent); top: -100px; right: -100px; animation-delay: 0s; }
.blob2 { width: 350px; height: 350px; background: radial-gradient(circle, rgba(233,168,36,0.15), transparent); bottom: -50px; left: -50px; animation-delay: 2s; }
.blob3 { width: 250px; height: 250px; background: radial-gradient(circle, rgba(231,111,42,0.1), transparent); top: 40%; left: 40%; animation-delay: 4s; }
@keyframes float {
  0%,100% { transform: translateY(0) scale(1); }
  50% { transform: translateY(-20px) scale(1.05); }
}

/* Diagonal stripe texture */
.hero::before {
  content: '';
  position: absolute; inset: 0;
  background-image: repeating-linear-gradient(
    -45deg, transparent, transparent 40px,
    rgba(255,255,255,0.01) 40px, rgba(255,255,255,0.01) 41px
  );
}

.hero-inner {
  position: relative; z-index: 2;
  display: grid; grid-template-columns: 1.1fr 0.9fr;
  gap: 4rem; align-items: center;
  max-width: 1200px; margin: 0 auto; width: 100%;
}

.hero-tag {
  display: inline-flex; align-items: center; gap: 0.5rem;
  background: rgba(82,183,136,0.2);
  border: 1px solid rgba(82,183,136,0.4);
  color: var(--green-light);
  padding: 0.4rem 1rem; border-radius: 100px;
  font-size: 0.82rem; font-weight: 700;
  letter-spacing: 0.05em; text-transform: uppercase;
  margin-bottom: 1.5rem;
  animation: fadeSlideUp 0.6s ease both;
}

.hero h1 {
  font-family: 'Fraunces', serif;
  font-size: clamp(3rem, 5.5vw, 5.5rem);
  font-weight: 900;
  color: var(--white);
  line-height: 1.0;
  margin-bottom: 1.5rem;
  animation: fadeSlideUp 0.6s ease 0.1s both;
}
.hero h1 .line2 { color: var(--gold); display: block; }
.hero h1 .line3 { color: var(--green-light); display: block; font-style: italic; font-weight: 300; font-size: 0.7em; }

.hero-desc {
  color: rgba(255,255,255,0.72);
  font-size: 1.05rem; line-height: 1.75;
  max-width: 480px; margin-bottom: 2.5rem;
  animation: fadeSlideUp 0.6s ease 0.2s both;
}

.hero-btns {
  display: flex; gap: 1rem; flex-wrap: wrap;
  animation: fadeSlideUp 0.6s ease 0.3s both;
}

.btn-hero-main {
  padding: 0.9rem 2rem;
  background: var(--gold); color: var(--earth);
  border: none; border-radius: 16px;
  font-family: 'Nunito', sans-serif;
  font-size: 1rem; font-weight: 800; cursor: pointer;
  transition: all 0.25s; text-decoration: none; display: inline-block;
  box-shadow: 0 4px 20px rgba(233,168,36,0.4);
}
.btn-hero-main:hover { transform: translateY(-3px); box-shadow: 0 10px 30px rgba(233,168,36,0.5); }

.btn-hero-ghost {
  padding: 0.9rem 2rem;
  background: rgba(255,255,255,0.1); color: white;
  border: 1.5px solid rgba(255,255,255,0.25); border-radius: 16px;
  font-family: 'Nunito', sans-serif;
  font-size: 1rem; font-weight: 700; cursor: pointer;
  transition: all 0.25s; text-decoration: none; display: inline-block;
  backdrop-filter: blur(8px);
}
.btn-hero-ghost:hover { background: rgba(255,255,255,0.2); border-color: rgba(255,255,255,0.5); }

/* Hero trust bar */
.trust-bar {
  display: flex; gap: 2rem; margin-top: 3rem;
  padding-top: 2rem;
  border-top: 1px solid rgba(255,255,255,0.1);
  animation: fadeSlideUp 0.6s ease 0.4s both;
}
.trust-item { display: flex; align-items: center; gap: 0.6rem; }
.trust-icon { font-size: 1.2rem; }
.trust-text { font-size: 0.82rem; color: rgba(255,255,255,0.65); line-height: 1.3; }
.trust-text strong { color: white; display: block; }

/* Hero Right — floating product cards */
.hero-cards {
  position: relative; height: 520px;
  animation: fadeSlideUp 0.6s ease 0.2s both;
}

.floating-card {
  position: absolute;
  background: white;
  border-radius: 24px;
  padding: 1rem;
  box-shadow: 0 20px 60px rgba(0,0,0,0.25);
  cursor: pointer;
  transition: transform 0.3s ease;
}
.floating-card:hover { transform: scale(1.05) rotate(0deg) !important; }

.fc-main {
  width: 200px; top: 30px; left: 50%;
  transform: translateX(-50%) rotate(-3deg);
  animation: floatCard1 4s ease-in-out infinite;
}
.fc-left {
  width: 160px; top: 200px; left: 0;
  transform: rotate(5deg);
  animation: floatCard2 5s ease-in-out infinite;
}
.fc-right {
  width: 155px; top: 150px; right: 0;
  transform: rotate(-4deg);
  animation: floatCard3 4.5s ease-in-out infinite;
}
.fc-bottom {
  width: 170px; bottom: 20px; left: 30%;
  transform: rotate(2deg);
  animation: floatCard1 5.5s ease-in-out infinite reverse;
}

@keyframes floatCard1 {
  0%,100% { transform: translateX(-50%) rotate(-3deg) translateY(0); }
  50% { transform: translateX(-50%) rotate(-3deg) translateY(-12px); }
}
@keyframes floatCard2 {
  0%,100% { transform: rotate(5deg) translateY(0); }
  50% { transform: rotate(5deg) translateY(-10px); }
}
@keyframes floatCard3 {
  0%,100% { transform: rotate(-4deg) translateY(0); }
  50% { transform: rotate(-4deg) translateY(-8px); }
}

.fc-emoji { font-size: 3rem; text-align: center; margin-bottom: 0.5rem; display: block; }
.fc-name { font-weight: 800; font-size: 0.85rem; color: var(--green-dark); margin-bottom: 0.25rem; }
.fc-farm { font-size: 0.72rem; color: var(--muted); }
.fc-price { font-family: 'Fraunces', serif; font-size: 1.1rem; font-weight: 700; color: var(--orange); margin-top: 0.4rem; }

.fc-badge-new {
  background: var(--gold); color: var(--earth);
  font-size: 0.62rem; font-weight: 800; padding: 0.15rem 0.5rem;
  border-radius: 100px; text-transform: uppercase; margin-top: 0.3rem; display: inline-block;
}

@keyframes fadeSlideUp {
  from { opacity: 0; transform: translateY(24px); }
  to { opacity: 1; transform: translateY(0); }
}

/* ── SEARCH BAR ── */
.search-bar-section {
  background: var(--green-dark);
  padding: 0 3rem 3rem;
}
.search-inner {
  max-width: 700px; margin: 0 auto;
  background: white;
  border-radius: 20px;
  padding: 0.5rem 0.5rem 0.5rem 1.5rem;
  display: flex; gap: 0.75rem; align-items: center;
  box-shadow: 0 20px 60px rgba(0,0,0,0.2);
}
.search-inner input {
  flex: 1; border: none; background: transparent;
  font-family: 'Nunito', sans-serif; font-size: 1rem; color: var(--text);
  outline: none;
}
.search-inner input::placeholder { color: #aaa; }
.search-filters {
  display: flex; gap: 0.4rem;
}
.sf-btn {
  padding: 0.45rem 0.9rem;
  background: var(--green-soft); color: var(--green-dark);
  border: none; border-radius: 10px;
  font-family: 'Nunito', sans-serif; font-size: 0.8rem; font-weight: 700;
  cursor: pointer; transition: all 0.2s; white-space: nowrap;
}
.sf-btn:hover { background: var(--green-pale); }
.search-go {
  padding: 0.7rem 1.4rem;
  background: var(--green-dark); color: white;
  border: none; border-radius: 14px;
  font-family: 'Nunito', sans-serif; font-size: 0.9rem; font-weight: 800;
  cursor: pointer; transition: all 0.2s;
}
.search-go:hover { background: var(--green-mid); }

/* ── QUICK CATEGORIES ── */
.quick-cats {
  background: var(--green-soft);
  padding: 2rem 3rem;
  display: flex; gap: 1rem;
  overflow-x: auto; scrollbar-width: none;
  align-items: center;
}
.quick-cats::-webkit-scrollbar { display: none; }
.qc-label { font-weight: 800; font-size: 0.85rem; color: var(--green-dark); white-space: nowrap; margin-right: 0.5rem; }
.qc-pill {
  display: flex; align-items: center; gap: 0.5rem;
  padding: 0.6rem 1.2rem;
  background: white; border-radius: 100px;
  font-size: 0.88rem; font-weight: 700; color: var(--green-dark);
  white-space: nowrap; cursor: pointer; border: 1.5px solid transparent;
  transition: all 0.2s; text-decoration: none;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
}
.qc-pill:hover { border-color: var(--green-light); transform: translateY(-2px); }
.qc-pill.active { background: var(--green-dark); color: white; }

/* ── SECTION ── */
.section { padding: 5rem 3rem; max-width: 1300px; margin: 0 auto; }
.s-eyebrow { font-size: 0.78rem; font-weight: 800; letter-spacing: 0.12em; text-transform: uppercase; color: var(--green-mid); margin-bottom: 0.5rem; }
.s-title { font-family: 'Fraunces', serif; font-size: clamp(1.8rem, 3vw, 2.5rem); font-weight: 900; color: var(--green-dark); line-height: 1.15; }
.s-title em { font-style: italic; color: var(--orange); }
.section-row { display: flex; align-items: flex-end; justify-content: space-between; margin-bottom: 2.5rem; gap: 1rem; }
.see-all {
  padding: 0.5rem 1.2rem;
  background: var(--green-pale); color: var(--green-dark);
  border: none; border-radius: 100px;
  font-family: 'Nunito', sans-serif; font-size: 0.85rem; font-weight: 800;
  cursor: pointer; transition: all 0.2s; white-space: nowrap; text-decoration: none;
}
.see-all:hover { background: var(--green-dark); color: white; }

/* ── PRODUCT GRID ── */
.prod-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.25rem; }

.prod-card {
  background: white; border-radius: 20px; overflow: hidden;
  transition: all 0.3s; cursor: pointer;
  border: 1.5px solid transparent;
}
.prod-card:hover { transform: translateY(-6px); border-color: var(--green-pale); box-shadow: 0 16px 40px rgba(27,67,50,0.1); }

.prod-img {
  height: 180px; display: flex; align-items: center;
  justify-content: center; font-size: 4.5rem;
  position: relative;
}

.prod-tag {
  position: absolute; top: 0.75rem; left: 0.75rem;
  padding: 0.2rem 0.65rem; border-radius: 100px;
  font-size: 0.7rem; font-weight: 800; text-transform: uppercase;
}
.tag-organic { background: var(--green-pale); color: var(--green-dark); }
.tag-new { background: var(--gold-light); color: var(--earth); }
.tag-hot { background: #FFE8E0; color: #C1440E; }

.wish-btn {
  position: absolute; top: 0.75rem; right: 0.75rem;
  width: 32px; height: 32px; background: white; border: none; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 0.9rem; cursor: pointer; box-shadow: 0 2px 8px rgba(0,0,0,0.1);
  transition: transform 0.2s;
}
.wish-btn:hover { transform: scale(1.2); }

.prod-body { padding: 1rem 1.1rem 1.2rem; }
.prod-farmer { font-size: 0.73rem; font-weight: 700; color: var(--green-mid); text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: 0.3rem; }
.prod-name { font-family: 'Fraunces', serif; font-size: 1rem; font-weight: 700; color: var(--green-dark); margin-bottom: 0.4rem; line-height: 1.3; }
.prod-stars { font-size: 0.8rem; color: var(--gold); margin-bottom: 0.75rem; }
.prod-stars span { color: var(--muted); margin-left: 0.25rem; }

.prod-footer { display: flex; align-items: center; justify-content: space-between; }
.prod-price { font-family: 'Fraunces', serif; font-size: 1.35rem; font-weight: 900; color: var(--green-dark); }
.prod-price sub { font-family: 'Nunito', sans-serif; font-size: 0.72rem; font-weight: 600; color: var(--muted); }

.add-btn {
  width: 38px; height: 38px; background: var(--green-dark); color: white;
  border: none; border-radius: 12px; font-size: 1.3rem;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; transition: all 0.2s;
}
.add-btn:hover { background: var(--green-light); transform: rotate(90deg) scale(1.1); }

/* img bg variants */
.ib1 { background: linear-gradient(135deg,#FEF3C7,#FDE68A); }
.ib2 { background: linear-gradient(135deg,#D1FAE5,#A7F3D0); }
.ib3 { background: linear-gradient(135deg,#FFE4E6,#FECDD3); }
.ib4 { background: linear-gradient(135deg,#EDE9FE,#DDD6FE); }
.ib5 { background: linear-gradient(135deg,#FFF7ED,#FED7AA); }
.ib6 { background: linear-gradient(135deg,#F0FDF4,#BBF7D0); }
.ib7 { background: linear-gradient(135deg,#FEF9C3,#FEF08A); }
.ib8 { background: linear-gradient(135deg,#FCE7F3,#FBCFE8); }

/* ── WHY US STRIP ── */
.why-strip {
  background: var(--green-dark);
  padding: 3rem;
}
.why-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 2rem; max-width: 1200px; margin: 0 auto; }
.why-card { text-align: center; }
.why-icon { font-size: 2.5rem; margin-bottom: 0.75rem; display: block; }
.why-title { font-weight: 800; color: white; font-size: 1rem; margin-bottom: 0.4rem; }
.why-desc { font-size: 0.83rem; color: rgba(255,255,255,0.6); line-height: 1.6; }

/* ── FARMER SPOTLIGHT ── */
.spotlight-wrap { background: var(--warm); }
.spotlight-inner { max-width: 1200px; margin: 0 auto; padding: 5rem 3rem; }
.spotlight-grid { display: grid; grid-template-columns: 1fr 1.5fr; gap: 4rem; align-items: center; }

.spot-portrait-wrap { position: relative; }
.spot-portrait {
  width: 100%; aspect-ratio: 4/5;
  background: linear-gradient(135deg, var(--green-dark), var(--green-mid));
  border-radius: 32px;
  display: flex; align-items: center; justify-content: center;
  font-size: 7rem;
  overflow: hidden; position: relative;
}
.spot-portrait::after {
  content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 40%;
  background: linear-gradient(to top, rgba(27,67,50,0.6), transparent);
}
.spot-badge {
  position: absolute; bottom: -16px; right: -16px;
  background: var(--gold); border-radius: 20px;
  padding: 0.75rem 1.2rem;
  box-shadow: 0 8px 24px rgba(233,168,36,0.4);
}
.spot-badge-val { font-family: 'Fraunces', serif; font-size: 1.5rem; font-weight: 900; color: var(--earth); display: block; }
.spot-badge-key { font-size: 0.72rem; font-weight: 700; color: var(--earth); opacity: 0.8; }

.spot-content .s-eyebrow { margin-bottom: 0.5rem; }
.spot-content h2 { font-family: 'Fraunces', serif; font-size: 2.2rem; font-weight: 900; color: var(--green-dark); margin-bottom: 1rem; line-height: 1.2; }
.spot-content p { color: var(--muted); line-height: 1.75; margin-bottom: 1.5rem; font-size: 0.95rem; }

.spot-metrics { display: flex; gap: 2rem; margin-bottom: 2rem; }
.sm-item { }
.sm-val { font-family: 'Fraunces', serif; font-size: 1.6rem; font-weight: 900; color: var(--green-dark); display: block; }
.sm-key { font-size: 0.78rem; color: var(--muted); }

.btn-green {
  padding: 0.8rem 1.8rem;
  background: var(--green-dark); color: white;
  border: none; border-radius: 14px;
  font-family: 'Nunito', sans-serif; font-size: 0.95rem; font-weight: 800;
  cursor: pointer; transition: all 0.25s; text-decoration: none; display: inline-block;
}
.btn-green:hover { background: var(--green-mid); transform: translateY(-2px); }

/* ── DASHBOARD ── */
.dash-section { background: var(--cream); }
.dash-inner { max-width: 1200px; margin: 0 auto; padding: 5rem 3rem; }
.dash-grid { display: grid; grid-template-columns: 1fr 1.5fr; gap: 4rem; align-items: start; }

.dash-left h2 { font-family: 'Fraunces', serif; font-size: 2rem; font-weight: 900; color: var(--green-dark); margin-bottom: 1rem; }
.dash-left p { color: var(--muted); line-height: 1.7; margin-bottom: 1.5rem; font-size: 0.95rem; }

.feat-check { list-style: none; margin-bottom: 2rem; }
.feat-check li {
  display: flex; align-items: center; gap: 0.75rem;
  padding: 0.6rem 0; border-bottom: 1px solid var(--green-soft);
  font-size: 0.92rem; color: var(--text);
}
.feat-check li:last-child { border-bottom: none; }
.check-icon {
  width: 24px; height: 24px; min-width: 24px;
  background: var(--green-pale); color: var(--green-dark);
  border-radius: 8px; display: flex; align-items: center;
  justify-content: center; font-size: 0.75rem; font-weight: 900;
}

/* Dashboard card */
.db-card {
  background: white; border-radius: 24px;
  padding: 1.5rem;
  box-shadow: 0 8px 40px rgba(27,67,50,0.08);
  border: 1px solid var(--green-soft);
}
.db-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.25rem; }
.db-title { font-weight: 800; font-size: 0.95rem; color: var(--green-dark); }
.db-chip { background: var(--green-soft); color: var(--green-mid); font-size: 0.75rem; font-weight: 700; padding: 0.25rem 0.75rem; border-radius: 100px; }

